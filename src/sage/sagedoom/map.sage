# map.sage — SageDoom level data and collision detection
# Classic Wolfenstein-style 2D grid map.
from math_util import floor_approx

# ---------------------------------------------------------------
# E1M1-inspired test map (0=empty, 1-4=wall types)
# ---------------------------------------------------------------

