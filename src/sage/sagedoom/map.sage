# Wall color palette (R, G, B) for each wall type (index 0-4)
let WALL_COLORS = [
    [0,   0,   0  ],   # 0 = empty (should never be rendered)
    [80,  80,  80 ],   # 1 = gray stone
    [60,  30,  20 ],   # 2 = brown brick
    [20,  40,  60 ],   # 3 = blue metal
    [70,  10,  10 ],   # 4 = red hell-stone
]

class Level:
    proc init(self, map_data):
        self.grid    = map_data
        self.height  = len(map_data)
        self.width   = len(map_data[0])
        self.colors  = WALL_COLORS

    proc get_cell(self, x, y):
        # Map coordinates to grid cell
        let gx = floor_approx(x)
        let gy = floor_approx(y)
        if gx < 0 or gx >= self.width or gy < 0 or gy >= self.height:
            return 0
        return self.grid[gy][gx]

    proc is_solid(self, x, y):
        return self.get_cell(x, y) != 0

    proc get_color(self, cell_type):
        if cell_type < 0 or cell_type >= len(self.colors):
            cell_type = 1
        return self.colors[cell_type]
